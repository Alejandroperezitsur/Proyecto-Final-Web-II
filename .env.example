# Configuración de SICEnet (.env)
# Copia este archivo a ".env" y ajusta los valores.

# Nombre de la aplicación
APP_NAME=SICEnet

# Base path cuando se despliega en subdirectorio (ej. /PWBII/SICEnet/public)
# Déjalo vacío si se sirve en raíz del dominio
APP_BASE_PATH=

# URL pública de la app (opcional)
APP_URL=

# Indica si se sirve por HTTPS (true/false) para cookies seguras
APP_HTTPS=false

# Base de datos
DB_HOST=127.0.0.1
DB_NAME=sicenet
DB_USER=root
DB_PASS=root